# Task 4 - Basic Chatbot
def chatbot():
    print("🤖 Welcome to Basic Chatbot!")
    print("Type 'bye' to exit the chat.\n")
    while True:
        user = input("You: ").lower().strip()
        if user == "hello" or user == "hi":
            print("Bot: Hi! Nice to meet you.")
        elif user == "how are you":
            print("Bot: I'm fine, thanks! How about you?")
        elif user == "i am fine":
            print("Bot: That's great to hear!")
        elif user == "what is your name":
            print("Bot: I am a Basic Chatbot created using Python.")
        elif user == "who created you":
            print("Bot: I was created by Kedika Pavan.")
        elif user == "help":
            print("Bot: You can say hello, ask my name, ask how I am, or type bye to exit.")
        elif user == "bye":
            print("Bot: Goodbye! Have a great day! 👋")
            break
        else:
            print("Bot: Sorry, I don't understand that. Please try another question.")
chatbot()
